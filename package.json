      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@chakra-ui/cli": "~3.28",
    "@eslint/js": "~9.39",
    "@vitejs/plugin-react": "~5.1",
    "eslint": "~9.39",
    "eslint-plugin-react": "~7.37",
    "globals": "~16.5",
