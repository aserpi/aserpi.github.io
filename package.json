  "type": "module",
  "dependencies": {
    "@chakra-ui/react": "~3.28",
    "@emotion/react": "~11.14",
    "next-themes": "~0.4.6",
    "prop-types": "~15.8",
    "react": "~18.3",
    "react-dom": "~18.3",
    "react-icons": "~5.5",
    "react-router-dom": "~7.9",
    "react-vertical-timeline-component": "~3.6",
    "typewriter-effect": "~2.22"
