    "lint-staged": "~16.2",
    "prettier": "~3.6",
    "vite": "~7.1",
    "vite-plugin-eslint": "~1.8"
  },
  "homepage": "https://aserpi.it",
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown",
      "eslint"
